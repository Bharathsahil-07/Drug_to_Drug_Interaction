# Auto detect text files and perform LF normalization
* text=auto

# Python files
*.py text eol=lf diff=python
*.pyw text eol=lf diff=python
*.pyx text eol=lf diff=python
*.pxd text eol=lf diff=python
*.pyi text eol=lf diff=python

# Python compiled files
*.pyc binary
*.pyo binary
*.pyd binary
*.so binary
*.dll binary
*.dylib binary
*.egg binary

# Jupyter Notebooks
*.ipynb text eol=lf linguist-documentation

# Data files
*.csv text eol=lf
*.tsv text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.smi text eol=lf
*.smiles text eol=lf

# Scientific data formats
*.sdf text eol=lf
*.mol text eol=lf
*.pdb text eol=lf
*.fasta text eol=lf
*.fastq text eol=lf

# Documentation
*.md text eol=lf linguist-documentation
*.rst text eol=lf linguist-documentation
*.tex text eol=lf linguist-documentation
LICENSE text eol=lf
README text eol=lf
CHANGELOG text eol=lf
AUTHORS text eol=lf
CONTRIBUTING text eol=lf

# Configuration files
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.config text eol=lf
*.toml text eol=lf
*.properties text eol=lf
requirements*.txt text eol=lf
setup.py text eol=lf
setup.cfg text eol=lf
pyproject.toml text eol=lf
MANIFEST.in text eol=lf
tox.ini text eol=lf
.editorconfig text eol=lf

# Web files
*.html text eol=lf diff=html linguist-vendored
*.htm text eol=lf diff=html linguist-vendored
*.css text eol=lf diff=css
*.scss text eol=lf diff=css
*.sass text eol=lf diff=css
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.json text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf

# Batch scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf
.gitmodules text eol=lf
.gitkeep text eol=lf

# Docker files
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
.dockerignore text eol=lf

# CI/CD
.travis.yml text eol=lf
.gitlab-ci.yml text eol=lf
appveyor.yml text eol=lf
.circleci/config.yml text eol=lf
Jenkinsfile text eol=lf

# Machine Learning model files (binary)
*.pkl binary
*.pickle binary
*.h5 binary
*.hdf5 binary
*.hdf binary
*.npy binary
*.npz binary
*.joblib binary
*.sav binary

# PyTorch model files
*.pt binary
*.pth binary
*.ckpt binary
*.checkpoint binary

# TensorFlow model files
*.pb binary
*.meta binary
*.index binary
*.onnx binary
*.tflite binary

# Other ML formats
*.caffemodel binary
*.mlmodel binary
*.coreml binary

# Graph files
*.graph binary
*.dgl binary
*.graphml text eol=lf
*.gexf text eol=lf
*.gml text eol=lf

# Image files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.eps binary
*.bmp binary
*.tif binary
*.tiff binary
*.webp binary

# Plot/Figure files
*.pdf binary
*.ai binary
*.psd binary

# Archive files
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
*.rar binary
*.tgz binary
*.xz binary

# Database files
*.db binary
*.sqlite binary
*.sqlite3 binary
*.mdb binary

# Excel and Office files
*.xlsx binary
*.xls binary
*.xlsm binary
*.xlsb binary
*.doc binary
*.docx binary
*.ppt binary
*.pptx binary

# Molecular/Chemical data files (binary formats)
*.sdf.gz binary
*.mol2 binary
*.mae binary
*.dcd binary
*.xtc binary
*.trr binary

# Log files
*.log text eol=lf
*.out text eol=lf
*.err text eol=lf

# Results and metrics files
*_results.txt text eol=lf
*_metrics.txt text eol=lf
*_report.txt text eol=lf
ablation_results*.txt text eol=lf
diversity_results*.txt text eol=lf
metrics_report*.txt text eol=lf
rigorous_metrics*.txt text eol=lf
publication_metrics*.txt text eol=lf

# Export diff and merge drivers
*.csv merge=union
*.json merge=union

# Linguist overrides for accurate language statistics
*.ipynb linguist-documentation
*.md linguist-documentation
*.txt linguist-documentation
*.html linguist-vendored
*.css linguist-vendored
*.js linguist-vendored
static/* linguist-vendored
plots/* linguist-generated
plots_rigorous/* linguist-generated
final_plot/* linguist-generated
publication_figures/* linguist-generated

# Mark generated files
*_generated.py linguist-generated
*_auto.py linguist-generated

