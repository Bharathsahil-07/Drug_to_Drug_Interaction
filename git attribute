# Diff settings for specific file types
*.py diff=python
*.md diff=markdown
*.json diff=json

# End of file normalization
# Ensures files end with a newline
* text eol=lf

# Exception: Windows batch files must use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
